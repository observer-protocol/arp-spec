# Observer Protocol API Server Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# PRIORITY 1: REQUIRED ENVIRONMENT VARIABLES (Deployment Blockers)
# =============================================================================

# OP_WORKSPACE_PATH: Path to the observer-protocol workspace directory
# This replaces the hardcoded path for importing crypto_verification module
# Default: /home/futurebit/.openclaw/workspace/observer-protocol
OP_WORKSPACE_PATH=/home/futurebit/.openclaw/workspace/observer-protocol

# OP_ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins
# This replaces hardcoded allow_origins in CORS middleware
# Format: "https://domain1.com,https://domain2.com"
# Default: observerprotocol.org and agenticterminal.ai domains
OP_ALLOWED_ORIGINS="https://observerprotocol.org,https://www.observerprotocol.org,https://agenticterminal.ai,https://www.agenticterminal.ai"

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection URL
# Format: postgresql://username:password@host/database
DB_URL=postgresql://agentic_terminal:at_secure_2026@localhost/agentic_terminal_db

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# API Server Host and Port
API_HOST=0.0.0.0
API_PORT=8000

# Debug mode (set to "true" for development)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
